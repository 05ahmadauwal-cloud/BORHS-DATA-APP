{
  "appId": "com.borhsdata.app",
  "appName": "BORHS",
  "webDir": "dist",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#020617"
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#020617",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#020617",
      "overlaysWebView": false
    }
  }
}
